{
    "name": "swew/art-framework",
    "description": "A framework that is designed to fix the fatal flaw of other frameworks.",
    "license": "MIT",
    "authors": [
        {
            "name": "AVIL13",
            "email": "avil@swew.app"
        }
    ],
    "autoload": {
        "psr-4": {
            "SWEW\\Framework\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ],
        "exclude-from-classmap": [
            "spec",
            "/Tests/",
            "/test/",
            "/tests/"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "symfony/http-foundation": "^6.0",
        "nikic/fast-route": "^1.3",
        "rakit/validation": "^1.4"
    },
    "require-dev": {
        "kahlan/kahlan": "^5.2"
    }
}
